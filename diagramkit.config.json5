{
  // Keep generated theme variants beside each source diagram file.
  sameFolder: true,

  // Prefer SVG for docs surfaces in this repo.
  defaultFormats: ["svg"],

  // Always generate both light and dark variants for docs embedding.
  defaultTheme: "both",

  // Keep the incremental-build manifest hidden when rendering in-place.
  manifestFile: ".diagramkit-manifest.json",

  // Let the renderer auto-rebalance flowcharts whose ratio drifts outside
  // [target/tolerance, target*tolerance]. Catches ~70% of aspect-ratio
  // issues before they reach the agent fix loop.
  mermaidLayout: { mode: "auto", targetAspectRatio: 1.333, tolerance: 2.5 },
}
