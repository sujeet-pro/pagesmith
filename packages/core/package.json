{
  "name": "@pagesmith/core",
  "version": "0.4.3",
  "description": "File-based CMS — schema-validated collections, lazy markdown rendering, and runtime CSS/JS exports",
  "keywords": [
    "cms",
    "collections",
    "content",
    "content-layer",
    "markdown",
    "static-site"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "author": "Sujeet <hello@sujeet.pro> (https://sujeet.pro)",
  "repository": {
    "type": "git",
    "url": "https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/core"
  },
  "files": [
    "dist/",
    "src/styles/",
    "assets/",
    "templates/",
    "docs/",
    "REFERENCE.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "import": "./dist/jsx-runtime/index.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "import": "./dist/jsx-runtime/index.mjs"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.mts",
      "import": "./dist/markdown/index.mjs"
    },
    "./css": {
      "types": "./dist/css/index.d.mts",
      "import": "./dist/css/index.mjs"
    },
    "./css/standalone": {
      "types": "./css.d.ts",
      "default": "./src/styles/standalone.css"
    },
    "./css/content": {
      "types": "./css.d.ts",
      "default": "./src/styles/content.css"
    },
    "./css/viewport": {
      "types": "./css.d.ts",
      "default": "./src/styles/viewport.css"
    },
    "./css/fonts": {
      "types": "./css.d.ts",
      "default": "./assets/fonts.css"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.mts",
      "import": "./dist/schemas/index.mjs"
    },
    "./loaders": {
      "types": "./dist/loaders/index.d.mts",
      "import": "./dist/loaders/index.mjs"
    },
    "./assets": {
      "types": "./dist/assets/index.d.mts",
      "import": "./dist/assets/index.mjs"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "import": "./dist/runtime/index.mjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.mts",
      "import": "./dist/ai/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite/index.d.mts",
      "import": "./dist/vite/index.mjs"
    },
    "./ssg-utils": {
      "types": "./dist/ssg-utils/index.d.mts",
      "import": "./dist/ssg-utils/index.mjs"
    },
    "./create": {
      "types": "./dist/create/index.d.mts",
      "import": "./dist/create/index.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.mts",
      "import": "./dist/mcp/index.mjs"
    },
    "./llms": "./docs/llms.txt",
    "./llms-full": "./docs/llms-full.txt",
    "./agents/usage": "./docs/agents/usage.md",
    "./agents/recipes": "./docs/agents/recipes.md",
    "./agents/changelog-notes": "./docs/agents/changelog-notes.md",
    "./agents/errors": "./docs/agents/errors.md",
    "./agents/migration": "./docs/agents/migration.md",
    "./agents/template": "./docs/agents/AGENTS.md.template",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "devalue": "^5.1.1",
    "fast-glob": "^3.3.0",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "lightningcss": "^1.32.0",
    "rehype-accessible-emojis": "^0.3.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-expressive-code": "^0.41.7",
    "rehype-external-links": "^3.0.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-github-alerts": "^0.1.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "remark-smartypants": "^3.0.2",
    "smol-toml": "^1.6.1",
    "unified": "^11.0.5",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.13"
  },
  "engines": {
    "node": ">=24"
  },
  "ai": {
    "context": "./docs/llms.txt",
    "fullContext": "./docs/llms-full.txt",
    "agentsDir": "./docs/agents"
  }
}
