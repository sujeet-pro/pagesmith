{
  "name": "@pagesmith/core",
  "version": "0.9.5",
  "description": "Headless content layer — schema-validated collections, lazy markdown rendering, loaders, and the Vite content plugin",
  "keywords": [
    "cms",
    "collections",
    "content",
    "content-layer",
    "markdown",
    "vite"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "author": "Sujeet <hello@sujeet.pro> (https://sujeet.pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/core"
  },
  "bin": {
    "pagesmith-core": "dist/cli/bin.mjs"
  },
  "files": [
    "dist/",
    "templates/",
    "skills/",
    "REFERENCE.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.mts",
      "import": "./dist/markdown/index.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.mts",
      "import": "./dist/schemas/index.mjs"
    },
    "./loaders": {
      "types": "./dist/loaders/index.d.mts",
      "import": "./dist/loaders/index.mjs"
    },
    "./assets": {
      "types": "./dist/assets/index.d.mts",
      "import": "./dist/assets/index.mjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.mts",
      "import": "./dist/ai/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite/index.d.mts",
      "import": "./dist/vite/index.mjs"
    },
    "./create": {
      "types": "./dist/create/index.d.mts",
      "import": "./dist/create/index.mjs"
    },
    "./cli-kit": {
      "types": "./dist/cli-kit/index.d.mts",
      "import": "./dist/cli-kit/index.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.mts",
      "import": "./dist/mcp/index.mjs"
    },
    "./skills/*": "./skills/*",
    "./llms": "./llms.txt",
    "./llms-full": "./llms-full.txt",
    "./agents/setup-core": "./skills/pagesmith-core-setup/references/setup-core.md",
    "./agents/usage": "./skills/pagesmith-core-setup/references/usage.md",
    "./agents/recipes": "./skills/pagesmith-core-setup/references/recipes.md",
    "./agents/changelog-notes": "./skills/pagesmith-core-setup/references/changelog-notes.md",
    "./agents/errors": "./skills/pagesmith-core-setup/references/errors.md",
    "./agents/migration": "./skills/pagesmith-core-setup/references/migration.md",
    "./agents/template": "./skills/pagesmith-core-setup/references/AGENTS.md.template",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "test": "vp test run"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cac": "^6.7.14",
    "devalue": "^5.1.1",
    "fast-glob": "^3.3.0",
    "gray-matter": "^4.0.3",
    "jiti": "^2.6.1",
    "json5": "^2.2.3",
    "rehype-accessible-emojis": "^0.3.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-github-alerts": "^0.1.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "remark-smartypants": "^3.0.2",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "smol-toml": "^1.6.1",
    "unified": "^11.0.5",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.13"
  },
  "engines": {
    "node": ">=24"
  },
  "ai": {
    "context": "./llms.txt",
    "fullContext": "./llms-full.txt",
    "agentsDir": "./skills/pagesmith-core-setup/references"
  }
}
