{
  "name": "@pagesmith/core",
  "version": "0.9.1",
  "description": "Headless content layer — schema-validated collections, lazy markdown rendering, loaders, and the Vite content plugin",
  "keywords": [
    "cms",
    "collections",
    "content",
    "content-layer",
    "markdown",
    "vite"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "author": "Sujeet <hello@sujeet.pro> (https://sujeet.pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/core"
  },
  "bin": {
    "pagesmith-core": "dist/cli/bin.mjs"
  },
  "files": [
    "dist/",
    "templates/",
    "ai-guidelines/",
    "REFERENCE.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.mts",
      "import": "./dist/markdown/index.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.mts",
      "import": "./dist/schemas/index.mjs"
    },
    "./loaders": {
      "types": "./dist/loaders/index.d.mts",
      "import": "./dist/loaders/index.mjs"
    },
    "./assets": {
      "types": "./dist/assets/index.d.mts",
      "import": "./dist/assets/index.mjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.mts",
      "import": "./dist/ai/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite/index.d.mts",
      "import": "./dist/vite/index.mjs"
    },
    "./create": {
      "types": "./dist/create/index.d.mts",
      "import": "./dist/create/index.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.mts",
      "import": "./dist/mcp/index.mjs"
    },
    "./ai-guidelines/*": "./ai-guidelines/*",
    "./llms": "./ai-guidelines/llms.txt",
    "./llms-full": "./ai-guidelines/llms-full.txt",
    "./agents/setup-core": "./ai-guidelines/setup-core.md",
    "./agents/usage": "./ai-guidelines/usage.md",
    "./agents/recipes": "./ai-guidelines/recipes.md",
    "./agents/changelog-notes": "./ai-guidelines/changelog-notes.md",
    "./agents/errors": "./ai-guidelines/errors.md",
    "./agents/migration": "./ai-guidelines/migration.md",
    "./agents/template": "./ai-guidelines/AGENTS.md.template",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "devalue": "^5.1.1",
    "fast-glob": "^3.3.0",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "rehype-accessible-emojis": "^0.3.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-github-alerts": "^0.1.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "remark-smartypants": "^3.0.2",
    "sharp": "^0.34.5",
    "shiki": "^3.23.0",
    "smol-toml": "^1.6.1",
    "unified": "^11.0.5",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.13"
  },
  "engines": {
    "node": ">=24"
  },
  "ai": {
    "context": "./ai-guidelines/llms.txt",
    "fullContext": "./ai-guidelines/llms-full.txt",
    "agentsDir": "./ai-guidelines"
  }
}
