{
  "name": "pagesmith",
  "version": "0.1.0",
  "description": "Runtime-agnostic static site generator with default theme, diagrams, and custom JSX runtime",
  "bin": {
    "pagesmith": "./cli/bin.js"
  },
  "files": [
    "dist/",
    "src/",
    "schemas/",
    "theme/",
    "cli/"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "bun": "./src/index.ts",
      "deno": "./src/index.ts",
      "import": "./dist/index.mjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "bun": "./src/jsx-runtime/index.ts",
      "deno": "./src/jsx-runtime/index.ts",
      "import": "./dist/jsx-runtime/index.mjs"
    },
    "./schemas": {
      "bun": "./schemas/index.ts",
      "deno": "./schemas/index.ts",
      "import": "./dist/schemas/index.mjs"
    },
    "./theme/styles/*": "./theme/styles/*"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run"
  },
  "dependencies": {
    "@pagesmith/core": "*",
    "@shikijs/rehype": "^3.0.0",
    "chokidar": "^4.0.3",
    "diagramkit": "file:../../../diagramkit",
    "gray-matter": "^4.0.3",
    "hast": "^1.0.0",
    "json5": "^2.2.3",
    "lightningcss": "^1.32.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "rolldown": "^1.0.0-rc.10",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "vite-plus": "^0.1.13"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {}
}
