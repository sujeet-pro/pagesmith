{
  "name": "pagesmith",
  "version": "0.1.0",
  "description": "Runtime-agnostic static site generator with default theme, diagrams, and custom JSX runtime",
  "type": "module",
  "bin": {
    "pagesmith": "./cli/bin.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "deno": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./jsx-runtime": {
      "bun": "./src/jsx-runtime/index.ts",
      "import": "./dist/jsx-runtime/index.js"
    },
    "./schemas": {
      "bun": "./schemas/index.ts",
      "import": "./dist/schemas/index.js"
    },
    "./schemas/*": {
      "bun": "./schemas/*.ts",
      "import": "./dist/schemas/*.js"
    },
    "./theme/styles/*": "./theme/styles/*"
  },
  "files": [
    "dist/",
    "src/",
    "schemas/",
    "theme/",
    "cli/"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest"
  },
  "dependencies": {
    "@shikijs/rehype": "^3.0.0",
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "hast": "^1.0.0",
    "json5": "^2.2.3",
    "lightningcss": "^1.32.0",
    "mermaid-isomorphic": "^3.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "rolldown": "^1.0.0-rc.10",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "tsx": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tsx": {
      "optional": true
    }
  }
}
