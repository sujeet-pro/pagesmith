{
  "name": "@pagesmith/site",
  "version": "0.9.5",
  "description": "Pagesmith site toolkit — re-exported content APIs, JSX runtime, CSS/runtime exports, SSG Vite plugins, and a preset-driven pagesmith CLI",
  "keywords": [
    "jsx",
    "pagesmith",
    "static-site",
    "vite"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/site",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "author": "Sujeet <hello@sujeet.pro> (https://sujeet.pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/site"
  },
  "bin": {
    "pagesmith": "dist/cli/bin.mjs",
    "pagesmith-site": "dist/cli/bin.mjs"
  },
  "files": [
    "dist/",
    "src/styles/",
    "assets/",
    "css.d.ts",
    "skills/",
    "REFERENCE.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.mts",
      "import": "./dist/markdown/index.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.mts",
      "import": "./dist/schemas/index.mjs"
    },
    "./loaders": {
      "types": "./dist/loaders/index.d.mts",
      "import": "./dist/loaders/index.mjs"
    },
    "./assets": {
      "types": "./dist/assets/index.d.mts",
      "import": "./dist/assets/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs"
    },
    "./preset": {
      "types": "./dist/preset.d.mts",
      "import": "./dist/preset.mjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "import": "./dist/jsx-runtime/index.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime/index.d.mts",
      "import": "./dist/jsx-dev-runtime/index.mjs"
    },
    "./css": {
      "types": "./dist/css/index.d.mts",
      "import": "./dist/css/index.mjs"
    },
    "./css/chrome": {
      "types": "./css.d.ts",
      "default": "./src/styles/chrome.css"
    },
    "./css/standalone": {
      "types": "./css.d.ts",
      "default": "./src/styles/standalone.css"
    },
    "./css/content": {
      "types": "./css.d.ts",
      "default": "./src/styles/content.css"
    },
    "./css/code-block": {
      "types": "./css.d.ts",
      "default": "./src/styles/code/block.css"
    },
    "./css/code-inline": {
      "types": "./css.d.ts",
      "default": "./src/styles/code/inline.css"
    },
    "./css/tabs": {
      "types": "./css.d.ts",
      "default": "./src/styles/code/tabs.css"
    },
    "./css/viewport": {
      "types": "./css.d.ts",
      "default": "./src/styles/viewport.css"
    },
    "./css/fonts": {
      "types": "./css.d.ts",
      "default": "./assets/fonts.css"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "import": "./dist/runtime/index.mjs"
    },
    "./runtime/chrome": {
      "types": "./dist/runtime/chrome.d.mts",
      "import": "./dist/runtime/chrome.mjs"
    },
    "./runtime/content": {
      "types": "./dist/runtime/content.d.mts",
      "import": "./dist/runtime/content.mjs"
    },
    "./runtime/standalone": {
      "types": "./dist/runtime/standalone.d.mts",
      "import": "./dist/runtime/standalone.mjs"
    },
    "./runtime/code-blocks": {
      "types": "./dist/runtime/code-blocks.d.mts",
      "import": "./dist/runtime/code-blocks.mjs"
    },
    "./runtime/code-tabs": {
      "types": "./dist/runtime/code-tabs.d.mts",
      "import": "./dist/runtime/code-tabs.mjs"
    },
    "./runtime/toc-highlight": {
      "types": "./dist/runtime/toc-highlight.d.mts",
      "import": "./dist/runtime/toc-highlight.mjs"
    },
    "./runtime/theme": {
      "types": "./dist/runtime/theme.d.mts",
      "import": "./dist/runtime/theme.mjs"
    },
    "./runtime/footer-year": {
      "types": "./dist/runtime/footer-year.d.mts",
      "import": "./dist/runtime/footer-year.mjs"
    },
    "./runtime/search-trigger": {
      "types": "./dist/runtime/search-trigger.d.mts",
      "import": "./dist/runtime/search-trigger.mjs"
    },
    "./runtime/sidebar": {
      "types": "./dist/runtime/sidebar.d.mts",
      "import": "./dist/runtime/sidebar.mjs"
    },
    "./runtime/skip-link": {
      "types": "./dist/runtime/skip-link.d.mts",
      "import": "./dist/runtime/skip-link.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.mts",
      "import": "./dist/components/index.mjs"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.mts",
      "import": "./dist/layouts/index.mjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.mts",
      "import": "./dist/theme/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite/index.d.mts",
      "import": "./dist/vite/index.mjs"
    },
    "./ssg-utils": {
      "types": "./dist/ssg-utils/index.d.mts",
      "import": "./dist/ssg-utils/index.mjs"
    },
    "./build-validator": {
      "types": "./dist/build-validator.d.mts",
      "import": "./dist/build-validator.mjs"
    },
    "./skills/*": "./skills/*",
    "./llms": "./llms.txt",
    "./llms-full": "./llms-full.txt",
    "./agents/setup-site": "./skills/pagesmith-site-setup/references/setup-site.md",
    "./agents/site-guidelines": "./skills/pagesmith-site-setup/references/site-guidelines.md",
    "./agents/usage": "./skills/pagesmith-site-setup/references/usage.md",
    "./agents/recipes": "./skills/pagesmith-site-setup/references/recipes.md",
    "./agents/changelog-notes": "./skills/pagesmith-site-setup/references/changelog-notes.md",
    "./agents/errors": "./skills/pagesmith-site-setup/references/errors.md",
    "./agents/migration": "./skills/pagesmith-site-setup/references/migration.md",
    "./agents/template": "./skills/pagesmith-site-setup/references/AGENTS.md.template",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "test": "vp test run"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@pagesmith/core": "0.9.5",
    "cac": "^6.7.14",
    "json5": "^2.2.3",
    "lightningcss": "^1.32.0",
    "pagefind": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  },
  "engines": {
    "node": ">=24"
  },
  "ai": {
    "context": "./llms.txt",
    "fullContext": "./llms-full.txt",
    "agentsDir": "./skills/pagesmith-site-setup/references"
  }
}
