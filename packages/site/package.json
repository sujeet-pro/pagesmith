{
  "name": "@pagesmith/site",
  "version": "0.7.0",
  "description": "Pagesmith site toolkit — JSX runtime, CSS/runtime exports, SSG Vite plugins, and a preset-driven pagesmith CLI",
  "keywords": [
    "jsx",
    "pagesmith",
    "static-site",
    "vite"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/site",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "author": "Sujeet <hello@sujeet.pro> (https://sujeet.pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/site"
  },
  "bin": {
    "pagesmith": "dist/cli/bin.mjs",
    "pagesmith-site": "dist/cli/bin.mjs"
  },
  "files": [
    "dist/",
    "src/styles/",
    "assets/",
    "ai-guidelines/",
    "REFERENCE.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./config": {
      "types": "./dist/config.d.mts",
      "import": "./dist/config.mjs"
    },
    "./preset": {
      "types": "./dist/preset.d.mts",
      "import": "./dist/preset.mjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "import": "./dist/jsx-runtime/index.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime/index.d.mts",
      "import": "./dist/jsx-dev-runtime/index.mjs"
    },
    "./css": {
      "types": "./dist/css/index.d.mts",
      "import": "./dist/css/index.mjs"
    },
    "./css/standalone": {
      "types": "./css.d.ts",
      "default": "./src/styles/standalone.css"
    },
    "./css/content": {
      "types": "./css.d.ts",
      "default": "./src/styles/content.css"
    },
    "./css/code-block": {
      "types": "./css.d.ts",
      "default": "./src/styles/code/block.css"
    },
    "./css/code-inline": {
      "types": "./css.d.ts",
      "default": "./src/styles/code/inline.css"
    },
    "./css/tabs": {
      "types": "./css.d.ts",
      "default": "./src/styles/code/tabs.css"
    },
    "./css/viewport": {
      "types": "./css.d.ts",
      "default": "./src/styles/viewport.css"
    },
    "./css/fonts": {
      "types": "./css.d.ts",
      "default": "./assets/fonts.css"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.mts",
      "import": "./dist/runtime/index.mjs"
    },
    "./runtime/content": {
      "types": "./dist/runtime/content.d.mts",
      "import": "./dist/runtime/content.mjs"
    },
    "./runtime/standalone": {
      "types": "./dist/runtime/standalone.d.mts",
      "import": "./dist/runtime/standalone.mjs"
    },
    "./runtime/code-blocks": {
      "types": "./dist/runtime/code-blocks.d.mts",
      "import": "./dist/runtime/code-blocks.mjs"
    },
    "./runtime/code-tabs": {
      "types": "./dist/runtime/code-tabs.d.mts",
      "import": "./dist/runtime/code-tabs.mjs"
    },
    "./runtime/toc-highlight": {
      "types": "./dist/runtime/toc-highlight.d.mts",
      "import": "./dist/runtime/toc-highlight.mjs"
    },
    "./runtime/theme": {
      "types": "./dist/runtime/theme.d.mts",
      "import": "./dist/runtime/theme.mjs"
    },
    "./vite": {
      "types": "./dist/vite/index.d.mts",
      "import": "./dist/vite/index.mjs"
    },
    "./ssg-utils": {
      "types": "./dist/ssg-utils/index.d.mts",
      "import": "./dist/ssg-utils/index.mjs"
    },
    "./ai-guidelines/*": "./ai-guidelines/*",
    "./llms": "./ai-guidelines/llms.txt",
    "./llms-full": "./ai-guidelines/llms-full.txt",
    "./agents/setup-site": "./ai-guidelines/setup-site.md",
    "./agents/site-guidelines": "./ai-guidelines/site-guidelines.md",
    "./agents/usage": "./ai-guidelines/usage.md",
    "./agents/recipes": "./ai-guidelines/recipes.md",
    "./agents/changelog-notes": "./ai-guidelines/changelog-notes.md",
    "./agents/errors": "./ai-guidelines/errors.md",
    "./agents/migration": "./ai-guidelines/migration.md",
    "./agents/template": "./ai-guidelines/AGENTS.md.template",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run"
  },
  "dependencies": {
    "@pagesmith/core": "0.8.0",
    "json5": "^2.2.3",
    "lightningcss": "^1.32.0",
    "pagefind": "^1.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  },
  "engines": {
    "node": ">=24"
  },
  "ai": {
    "context": "./ai-guidelines/llms.txt",
    "fullContext": "./ai-guidelines/llms-full.txt",
    "agentsDir": "./ai-guidelines"
  }
}
