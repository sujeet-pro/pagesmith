{
  "name": "@pagesmith/docs",
  "version": "0.1.0",
  "description": "Convention-based documentation package built on @pagesmith/core",
  "keywords": [
    "cms",
    "docs",
    "documentation",
    "markdown",
    "static-site"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/docs",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/docs"
  },
  "bin": {
    "pagesmith": "./dist/cli/bin.mjs"
  },
  "files": [
    "dist/",
    "theme/",
    "src/styles/"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs"
    },
    "./schemas": {
      "import": "./dist/schemas/index.mjs"
    },
    "./schemas/*": {
      "import": "./dist/schemas/*.mjs"
    },
    "./preset": {
      "import": "./dist/preset.mjs"
    }
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run"
  },
  "dependencies": {
    "lightningcss": "^1.32.0",
    "pagefind": "^1.3.0",
    "rehype-mathjax": "^7.1.0",
    "rolldown": "^1.0.0-rc.10"
  },
  "devDependencies": {
    "@pagesmith/core": "*",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "json5": "^2.2.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-mathjax": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "typescript": "^5.9.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite-plus": "^0.1.13",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
