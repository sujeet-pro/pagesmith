{
  "name": "@pagesmith/docs",
  "version": "0.3.0",
  "description": "Convention-based documentation package built on @pagesmith/core",
  "keywords": [
    "cms",
    "docs",
    "documentation",
    "markdown",
    "static-site"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/docs",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/docs"
  },
  "bin": {
    "pagesmith": "./dist/cli/bin.mjs"
  },
  "files": [
    "dist/",
    "theme/",
    "docs/",
    "REFERENCE.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.mts",
      "import": "./dist/schemas/index.mjs"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.mts",
      "import": "./dist/schemas/*.mjs"
    },
    "./preset": {
      "types": "./dist/preset.d.mts",
      "import": "./dist/preset.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.mts",
      "import": "./dist/mcp/server.mjs"
    },
    "./llms": "./docs/llms.txt",
    "./llms-full": "./docs/llms-full.txt",
    "./agents/usage": "./docs/agents/usage.md",
    "./agents/recipes": "./docs/agents/recipes.md",
    "./agents/changelog-notes": "./docs/agents/changelog-notes.md",
    "./agents/template": "./docs/agents/AGENTS.md.template"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pagesmith/core": "*",
    "chokidar": "^5.0.0",
    "json5": "^2.2.3",
    "pagefind": "^1.3.0",
    "rolldown": "^1.0.0-rc.13",
    "unist-util-visit": "^5.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2",
    "vite-plus": "0.1.13"
  },
  "ai": {
    "context": "./docs/llms.txt",
    "fullContext": "./docs/llms-full.txt",
    "agentsDir": "./docs/agents",
    "mcp": {
      "entry": "./dist/mcp/server.mjs",
      "command": "pagesmith mcp --stdio"
    }
  }
}
