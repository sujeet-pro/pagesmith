{
  "name": "@pagesmith/docs",
  "version": "0.8.0",
  "description": "Convention-based documentation package built on the Pagesmith site/content stack",
  "keywords": [
    "cms",
    "docs",
    "documentation",
    "markdown",
    "static-site"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/docs",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "author": "Sujeet <hello@sujeet.pro> (https://sujeet.pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/docs"
  },
  "bin": {
    "pagesmith-docs": "dist/cli/bin.mjs"
  },
  "files": [
    "dist/",
    "theme/",
    "ai-guidelines/",
    "schemas/",
    "REFERENCE.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.mts",
      "import": "./dist/components/index.mjs"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.mts",
      "import": "./dist/layouts/index.mjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "import": "./dist/jsx-runtime/index.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime/index.d.mts",
      "import": "./dist/jsx-dev-runtime/index.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.mts",
      "import": "./dist/schemas/index.mjs"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.mts",
      "import": "./dist/schemas/*.mjs"
    },
    "./preset": {
      "types": "./dist/preset.d.mts",
      "import": "./dist/preset.mjs"
    },
    "./theme": {
      "types": "./dist/theme.d.mts",
      "import": "./dist/theme.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.mts",
      "import": "./dist/mcp/server.mjs"
    },
    "./ai-guidelines/*": "./ai-guidelines/*",
    "./llms": "./ai-guidelines/llms.txt",
    "./llms-full": "./ai-guidelines/llms-full.txt",
    "./agents/setup-docs": "./ai-guidelines/setup-docs.md",
    "./agents/usage": "./ai-guidelines/usage.md",
    "./agents/recipes": "./ai-guidelines/recipes.md",
    "./agents/changelog-notes": "./ai-guidelines/changelog-notes.md",
    "./agents/errors": "./ai-guidelines/errors.md",
    "./agents/migration": "./ai-guidelines/migration.md",
    "./agents/template": "./ai-guidelines/AGENTS.md.template",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "generate:schemas": "vp pack && node ./scripts/generate-json-schemas.mjs",
    "test": "vp test run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pagesmith/core": "0.8.0",
    "@pagesmith/site": "0.8.0",
    "chokidar": "^5.0.0",
    "json5": "^2.2.3",
    "pagefind": "^1.5.0",
    "rolldown": "^1.0.0-rc.13",
    "unist-util-visit": "^5.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.13"
  },
  "engines": {
    "node": ">=24"
  },
  "ai": {
    "context": "./ai-guidelines/llms.txt",
    "fullContext": "./ai-guidelines/llms-full.txt",
    "agentsDir": "./ai-guidelines",
    "mcp": {
      "entry": "./dist/mcp/server.mjs",
      "command": "pagesmith-docs mcp --stdio"
    }
  }
}
