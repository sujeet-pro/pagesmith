{
  "name": "@pagesmith/docs",
  "version": "0.9.6",
  "description": "Convention-based documentation package built on the Pagesmith site/content stack",
  "keywords": [
    "cms",
    "docs",
    "documentation",
    "markdown",
    "static-site"
  ],
  "homepage": "https://github.com/sujeet-pro/pagesmith/tree/main/packages/docs",
  "bugs": {
    "url": "https://github.com/sujeet-pro/pagesmith/issues"
  },
  "license": "MIT",
  "author": "Sujeet <hello@sujeet.pro> (https://sujeet.pro)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sujeet-pro/pagesmith.git",
    "directory": "packages/docs"
  },
  "bin": {
    "pagesmith-docs": "dist/cli/bin.mjs"
  },
  "files": [
    "dist/",
    "theme/",
    "skills/",
    "schemas/",
    "REFERENCE.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./components": {
      "types": "./dist/components/index.d.mts",
      "import": "./dist/components/index.mjs"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.mts",
      "import": "./dist/layouts/index.mjs"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime/index.d.mts",
      "import": "./dist/jsx-runtime/index.mjs"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime/index.d.mts",
      "import": "./dist/jsx-dev-runtime/index.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.mts",
      "import": "./dist/schemas/index.mjs"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.mts",
      "import": "./dist/schemas/*.mjs"
    },
    "./preset": {
      "types": "./dist/preset.d.mts",
      "import": "./dist/preset.mjs"
    },
    "./theme": {
      "types": "./dist/theme.d.mts",
      "import": "./dist/theme.mjs"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.mts",
      "import": "./dist/mcp/server.mjs"
    },
    "./build-validator": {
      "types": "./dist/build-validator.d.mts",
      "import": "./dist/build-validator.mjs"
    },
    "./skills/*": "./skills/*",
    "./llms": "./llms.txt",
    "./llms-full": "./llms-full.txt",
    "./agents/setup-docs": "./skills/pagesmith-docs-setup/references/setup-docs.md",
    "./agents/usage": "./skills/pagesmith-docs-setup/references/usage.md",
    "./agents/recipes": "./skills/pagesmith-docs-setup/references/recipes.md",
    "./agents/changelog-notes": "./skills/pagesmith-docs-setup/references/changelog-notes.md",
    "./agents/errors": "./skills/pagesmith-docs-setup/references/errors.md",
    "./agents/migration": "./skills/pagesmith-docs-setup/references/migration.md",
    "./agents/template": "./skills/pagesmith-docs-setup/references/AGENTS.md.template",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "test": "vp test run",
    "generate:schemas": "vp pack && node ./scripts/generate-json-schemas.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@pagesmith/core": "0.9.6",
    "@pagesmith/site": "0.9.6",
    "cac": "^6.7.14",
    "chokidar": "^5.0.0",
    "json5": "^2.2.3",
    "pagefind": "^1.5.0",
    "rolldown": "^1.0.0-rc.13",
    "unist-util-visit": "^5.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.13"
  },
  "engines": {
    "node": ">=24"
  },
  "ai": {
    "context": "./llms.txt",
    "fullContext": "./llms-full.txt",
    "agentsDir": "./skills/pagesmith-docs-setup/references",
    "mcp": {
      "entry": "./dist/mcp/server.mjs",
      "command": "pagesmith-docs mcp --stdio"
    }
  }
}
