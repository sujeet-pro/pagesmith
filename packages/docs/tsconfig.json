{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "paths": {
      "@pagesmith/docs": ["./src/index.ts"],
      "@pagesmith/docs/*": ["./src/*.ts", "./src/*/index.ts"],
      "@pagesmith/core": ["../core/src/index.ts"],
      "@pagesmith/core/*": ["../core/src/*/index.ts"],
      "@pagesmith/site": ["../site/src/index.ts"],
      "@pagesmith/site/*": ["../site/src/*.ts", "../site/src/*/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "theme/**/*.ts", "theme/**/*.tsx"]
}
