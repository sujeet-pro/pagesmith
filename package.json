{
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/docs",
    "examples/with-vanilla-ejs",
    "examples/with-vanilla-hbs",
    "examples/with-react",
    "examples/with-solid",
    "examples/with-svelte",
    "examples/blog-site",
    "examples/doc-site",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "dev": "vp run dev:docs",
    "build": "vp run clean && vp run build:library && vp run build:landing && vp run build:docs && vp run build:examples",
    "build:library": "node scripts/build-packages.mjs",
    "build:docs": "vp run --filter @pagesmith/docs-site build",
    "build:examples": "vp run build:eg:blog-site && vp run build:eg:doc-site && vp run build:eg:vanilla-ejs && vp run build:eg:vanilla-hbs && vp run build:eg:react && vp run build:eg:solid && vp run build:eg:svelte",
    "build:eg:blog-site": "vp run --filter @pagesmith/example-blog-site build",
    "build:eg:doc-site": "vp run --filter @pagesmith/example-doc-site build",
    "build:eg:vanilla-ejs": "vp run --filter @pagesmith/example-with-vanilla-ejs build",
    "build:eg:vanilla-hbs": "vp run --filter @pagesmith/example-with-vanilla-hbs build",
    "build:eg:react": "vp run --filter @pagesmith/example-with-react build",
    "build:eg:solid": "vp run --filter @pagesmith/example-with-solid build",
    "build:eg:svelte": "vp run --filter @pagesmith/example-with-svelte build",
    "build:landing": "node scripts/build.mjs",
    "dev:docs": "vp run --filter @pagesmith/docs-site dev",
    "dev:eg:blog-site": "vp run --filter @pagesmith/example-blog-site dev",
    "dev:eg:doc-site": "vp run --filter @pagesmith/example-doc-site dev",
    "dev:eg:vanilla-ejs": "vp run --filter @pagesmith/example-with-vanilla-ejs dev",
    "dev:eg:vanilla-hbs": "vp run --filter @pagesmith/example-with-vanilla-hbs dev",
    "dev:eg:react": "vp run --filter @pagesmith/example-with-react dev",
    "dev:eg:solid": "vp run --filter @pagesmith/example-with-solid dev",
    "dev:eg:svelte": "vp run --filter @pagesmith/example-with-svelte dev",
    "clean": "rm -rf gh-pages packages/*/dist docs/dist examples/*/dist",
    "preview": "node scripts/preview-gh-pages.mjs",
    "validate:examples": "node scripts/validate-examples.mjs",
    "validate": "vp run build:library && vp run build:docs && vp run validate:examples && vp check && vp test run",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "prepare": "vp config"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vite-plus": "^0.1.13"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.13",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.13"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.12.0"
}
