{
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/docs",
    "packages/site",
    "examples/with-nextjs",
    "examples/with-vanilla-ejs",
    "examples/with-vanilla-hbs",
    "examples/with-react",
    "examples/with-solid",
    "examples/with-svelte",
    "examples/blog-site",
    "examples/doc-site",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "dev": "vp run dev:docs",
    "build": "vp run clean && vp run build:library && vp run build:landing && vp run build:docs && vp run build:examples",
    "build:library": "node --strip-types --no-warnings scripts/build-packages.ts",
    "sync:versions": "node --strip-types --no-warnings scripts/sync-package-versions.ts",
    "build:docs": "vp run --filter @pagesmith/docs-site build",
    "build:examples": "npm run build:eg:blog-site && npm run build:eg:doc-site && npm run build:eg:nextjs && npm run build:eg:vanilla-ejs && npm run build:eg:vanilla-hbs && npm run build:eg:react && npm run build:eg:solid && npm run build:eg:svelte",
    "build:eg:blog-site": "npm run --workspace @pagesmith/example-blog-site build",
    "build:eg:doc-site": "npm run --workspace @pagesmith/example-doc-site build",
    "build:eg:nextjs": "npm run --workspace @pagesmith/example-with-nextjs build",
    "build:eg:vanilla-ejs": "npm run --workspace @pagesmith/example-with-vanilla-ejs build",
    "build:eg:vanilla-hbs": "npm run --workspace @pagesmith/example-with-vanilla-hbs build",
    "build:eg:react": "npm run --workspace @pagesmith/example-with-react build",
    "build:eg:solid": "npm run --workspace @pagesmith/example-with-solid build",
    "build:eg:svelte": "npm run --workspace @pagesmith/example-with-svelte build",
    "build:landing": "node --strip-types --no-warnings scripts/build.ts",
    "dev:docs": "vp run --filter @pagesmith/docs-site dev",
    "dev:eg:blog-site": "vp run --filter @pagesmith/example-blog-site dev",
    "dev:eg:doc-site": "vp run --filter @pagesmith/example-doc-site dev",
    "dev:eg:nextjs": "npm run --workspace @pagesmith/example-with-nextjs dev",
    "dev:eg:vanilla-ejs": "vp run --filter @pagesmith/example-with-vanilla-ejs dev",
    "dev:eg:vanilla-hbs": "vp run --filter @pagesmith/example-with-vanilla-hbs dev",
    "dev:eg:react": "vp run --filter @pagesmith/example-with-react dev",
    "dev:eg:solid": "vp run --filter @pagesmith/example-with-solid dev",
    "dev:eg:svelte": "vp run --filter @pagesmith/example-with-svelte dev",
    "clean": "rm -rf gh-pages packages/*/dist docs/dist examples/*/dist examples/*/.next examples/*/out",
    "preview": "node --strip-types --no-warnings scripts/preview-gh-pages.ts",
    "validate:examples": "node --strip-types --no-warnings scripts/validate-examples.ts",
    "validate": "vp run build:library && vp run build:docs && vp run validate:examples && vp check && vp test run",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "diagramkit:warmup": "diagramkit warmup",
    "validate:diagrams": "node --strip-types --no-warnings scripts/render-diagrams.ts --validate-only",
    "render:diagrams": "node --strip-types --no-warnings scripts/render-diagrams.ts",
    "render:diagrams:watch": "diagramkit render . --watch",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "prepare": "vp config"
  },
  "dependencies": {
    "diagramkit": "^0.2.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.12.1"
}
