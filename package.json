{
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/docs",
    "packages/site",
    "examples/blog-site",
    "examples/doc-site",
    "examples/frameworks/with-nextjs",
    "examples/frameworks/with-react",
    "examples/frameworks/with-solid",
    "examples/frameworks/with-svelte",
    "examples/frameworks/with-vanilla-ejs",
    "examples/frameworks/with-vanilla-hbs",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "dev": "npm run dev:docs",
    "build": "vp run clean && npm run build:library && npm run build:docs && npm run build:examples",
    "build:library": "node --strip-types --no-warnings scripts/build-packages.ts",
    "build:docs": "npm run --workspace @pagesmith/docs-site build",
    "build:examples": "npm run build:blog-site && npm run build:doc-site && npm run build:with-nextjs && npm run build:with-vanilla-ejs && npm run build:with-vanilla-hbs && npm run build:with-react && npm run build:with-solid && npm run build:with-svelte",
    "build:blog-site": "npm run --workspace @pagesmith/example-blog-site build",
    "build:doc-site": "npm run --workspace @pagesmith/example-doc-site build",
    "build:with-nextjs": "npm run --workspace @pagesmith/example-with-nextjs build",
    "build:with-vanilla-ejs": "npm run --workspace @pagesmith/example-with-vanilla-ejs build",
    "build:with-vanilla-hbs": "npm run --workspace @pagesmith/example-with-vanilla-hbs build",
    "build:with-react": "npm run --workspace @pagesmith/example-with-react build",
    "build:with-solid": "npm run --workspace @pagesmith/example-with-solid build",
    "build:with-svelte": "npm run --workspace @pagesmith/example-with-svelte build",
    "dev:docs": "npm run --workspace @pagesmith/docs-site dev",
    "dev:blog-site": "npm run --workspace @pagesmith/example-blog-site dev",
    "dev:doc-site": "npm run --workspace @pagesmith/example-doc-site dev",
    "dev:with-nextjs": "npm run --workspace @pagesmith/example-with-nextjs dev",
    "dev:with-vanilla-ejs": "npm run --workspace @pagesmith/example-with-vanilla-ejs dev",
    "dev:with-vanilla-hbs": "npm run --workspace @pagesmith/example-with-vanilla-hbs dev",
    "dev:with-react": "npm run --workspace @pagesmith/example-with-react dev",
    "dev:with-solid": "npm run --workspace @pagesmith/example-with-solid dev",
    "dev:with-svelte": "npm run --workspace @pagesmith/example-with-svelte dev",
    "preview:docs": "npm run preview",
    "preview:blog-site": "npm run --workspace @pagesmith/example-blog-site preview",
    "preview:doc-site": "npm run --workspace @pagesmith/example-doc-site preview",
    "preview:with-nextjs": "npm run --workspace @pagesmith/example-with-nextjs preview",
    "preview:with-vanilla-ejs": "npm run --workspace @pagesmith/example-with-vanilla-ejs preview",
    "preview:with-vanilla-hbs": "npm run --workspace @pagesmith/example-with-vanilla-hbs preview",
    "preview:with-react": "npm run --workspace @pagesmith/example-with-react preview",
    "preview:with-solid": "npm run --workspace @pagesmith/example-with-solid preview",
    "preview:with-svelte": "npm run --workspace @pagesmith/example-with-svelte preview",
    "sync:versions": "node --strip-types --no-warnings scripts/sync-package-versions.ts",
    "clean": "rm -rf gh-pages packages/*/dist docs/dist examples/*/dist examples/*/.next examples/*/out examples/frameworks/*/dist examples/frameworks/*/.next examples/frameworks/*/out",
    "preview": "node --strip-types --no-warnings scripts/preview-gh-pages.ts",
    "validate:examples": "node --strip-types --no-warnings scripts/validate-examples.ts",
    "validate:pagesmith": "node --strip-types --no-warnings scripts/validate-pagesmith.ts",
    "validate:pagesmith:full": "node --strip-types --no-warnings scripts/validate-pagesmith.ts --full",
    "validate": "npm run build:library && npm run build:docs && npm run validate:examples && npm run validate:pagesmith && npm run check && npm run test",
    "cicd": "npm run check && npm run build && npm run validate:diagrams && npm run validate:examples && npm run test && npm run e2e",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "diagramkit:warmup": "diagramkit warmup",
    "validate:diagrams": "node --strip-types --no-warnings scripts/render-diagrams.ts --validate-only",
    "render:diagrams": "node --strip-types --no-warnings scripts/render-diagrams.ts",
    "render:diagrams:watch": "diagramkit render . --watch",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "prepare": "vp config"
  },
  "dependencies": {
    "diagramkit": "^0.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plus": "^0.1.16"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.12.1"
}
