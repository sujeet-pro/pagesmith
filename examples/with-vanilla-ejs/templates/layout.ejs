<!DOCTYPE html>
<html lang="en" class="color-scheme-auto theme-paper">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="light dark">
  <script>(function(){try{var p=JSON.parse(localStorage.getItem('pagesmith-theme'));if(p){var d=document.documentElement;if(p.colorScheme)d.className=d.className.replace(/color-scheme-\w+/,'color-scheme-'+p.colorScheme);if(p.theme)d.className=d.className.replace(/theme-[\w-]+/,'theme-'+p.theme)}}catch(e){}})()</script>
  <title><%= title %></title>
  <link rel="icon" href="<%= basePath %>favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="<%= basePath %>assets/fonts.css" />
  <style>
    <%- css %>
  </style>
  <link rel="stylesheet" href="<%= basePath %>pagefind/pagefind-component-ui.css" />
</head>
<body>
  <%
    // Define sidebar content as a reusable function to avoid duplication
    function renderSidebarContent() {
  %>
    <div class="doc-sidebar-section">
      <span class="doc-sidebar-heading">Navigation</span>
      <ul class="doc-sidebar-list">
        <li class="doc-sidebar-item<%= activePath === '/' ? ' active' : '' %>">
          <a href="<%= basePath %>" class="doc-sidebar-link">Home</a>
        </li>
        <li class="doc-sidebar-item<%= activePath.startsWith('/guide') ? ' active' : '' %>">
          <a href="<%= basePath %>guide/<%= sidebar.firstGuideSlug %>/" class="doc-sidebar-link">Guide</a>
        </li>
        <li class="doc-sidebar-item<%= activePath.startsWith('/features') ? ' active' : '' %>">
          <a href="<%= basePath %>features/<%= sidebar.firstFeaturesSlug %>/" class="doc-sidebar-link">Features</a>
        </li>
        <li class="doc-sidebar-item<%= activePath === '/about' ? ' active' : '' %>">
          <a href="<%= basePath %>about/" class="doc-sidebar-link">About</a>
        </li>
      </ul>
    </div>

    <div class="doc-sidebar-section">
      <span class="doc-sidebar-heading">Guide</span>
      <ul class="doc-sidebar-list">
        <% for (const group of sidebar.guideGroups) { %>
          <li class="doc-sidebar-item<%= group.items.some(i => activePath === '/guide/' + i.slug) ? ' expanded' : '' %>">
            <span class="doc-sidebar-link" style="font-weight: 500; color: var(--color-text-secondary)"><%= group.series %></span>
            <ul class="doc-sidebar-nested">
              <% for (const item of group.items) { %>
                <li class="doc-sidebar-item<%= activePath === '/guide/' + item.slug ? ' active' : '' %>">
                  <a href="<%= basePath %>guide/<%= item.slug %>/" class="doc-sidebar-link"><%= item.title %></a>
                </li>
              <% } %>
            </ul>
          </li>
        <% } %>
      </ul>
    </div>

    <div class="doc-sidebar-section">
      <span class="doc-sidebar-heading">Features</span>
      <ul class="doc-sidebar-list">
        <% for (const entry of sidebar.featuresEntries) { %>
          <li class="doc-sidebar-item<%= activePath === '/features/' + entry.slug ? ' active' : '' %>">
            <a href="<%= basePath %>features/<%= entry.slug %>/" class="doc-sidebar-link"><%= entry.title %></a>
          </li>
        <% } %>
      </ul>
    </div>
  <% } %>

  <header class="doc-header">
    <div class="doc-header-inner">
      <div class="doc-header-left">
        <button type="button" class="doc-sidebar-toggle" aria-label="Toggle sidebar">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 5h14M3 10h14M3 15h14" /></svg>
        </button>
        <a href="/pagesmith/" class="doc-logo">Pagesmith</a>
      </div>
      <nav class="doc-nav">
        <a href="<%= basePath %>"<%= activePath === '/' ? ' class="active"' : '' %>>Home</a>
        <a href="<%= basePath %>guide/<%= sidebar.firstGuideSlug %>/"<%= activePath.startsWith('/guide') ? ' class="active"' : '' %>>Guide</a>
        <a href="<%= basePath %>features/<%= sidebar.firstFeaturesSlug %>/"<%= activePath.startsWith('/features') ? ' class="active"' : '' %>>Features</a>
      </nav>
      <pagefind-modal-trigger class="doc-search-trigger"></pagefind-modal-trigger>
    </div>
  </header>

  <% if (isHome) { %>
  <main class="doc-home">
    <div class="doc-home-content" data-pagefind-body>
      <%- body %>
      <footer class="doc-footer">
        <div class="doc-footer-links">
          <a href="https://github.com/sujeet-pro/pagesmith/tree/main/examples/with-vanilla-ejs">GitHub</a>
          <a href="https://github.com/sujeet-pro/pagesmith">Pagesmith</a>
        </div>
        <div class="doc-footer-theme no-js-hidden" data-footer-theme>
          <div class="doc-footer-theme-group">
            <span class="doc-footer-theme-label">Appearance</span>
            <div class="doc-footer-theme-options" data-footer-scheme>
              <button type="button" data-scheme="auto" class="active" aria-pressed="true">Auto</button>
              <button type="button" data-scheme="light" aria-pressed="false">Light</button>
              <button type="button" data-scheme="dark" aria-pressed="false">Dark</button>
            </div>
          </div>
          <div class="doc-footer-theme-group">
            <span class="doc-footer-theme-label">Theme</span>
            <div class="doc-footer-theme-options" data-footer-theme-type>
              <button type="button" data-theme="paper" class="active" aria-pressed="true">Paper</button>
              <button type="button" data-theme="high-contrast" aria-pressed="false">High Contrast</button>
            </div>
          </div>
        </div>
        <p class="doc-footer-copyright">&copy; 2026 Pagesmith &middot; Made with <a href="https://github.com/sujeet-pro/pagesmith">Pagesmith</a></p>
      </footer>
    </div>
  </main>
  <% } else { %>
  <div class="doc-layout">
    <aside class="doc-sidebar">
      <nav class="doc-sidebar-nav">
        <% renderSidebarContent() %>
      </nav>
    </aside>

    <main class="doc-main" data-pagefind-body>
      <%- body %>
      <footer class="doc-footer">
        <div class="doc-footer-links">
          <a href="https://github.com/sujeet-pro/pagesmith/tree/main/examples/with-vanilla-ejs">GitHub</a>
          <a href="https://github.com/sujeet-pro/pagesmith">Pagesmith</a>
        </div>
        <div class="doc-footer-theme no-js-hidden" data-footer-theme>
          <div class="doc-footer-theme-group">
            <span class="doc-footer-theme-label">Appearance</span>
            <div class="doc-footer-theme-options" data-footer-scheme>
              <button type="button" data-scheme="auto" class="active" aria-pressed="true">Auto</button>
              <button type="button" data-scheme="light" aria-pressed="false">Light</button>
              <button type="button" data-scheme="dark" aria-pressed="false">Dark</button>
            </div>
          </div>
          <div class="doc-footer-theme-group">
            <span class="doc-footer-theme-label">Theme</span>
            <div class="doc-footer-theme-options" data-footer-theme-type>
              <button type="button" data-theme="paper" class="active" aria-pressed="true">Paper</button>
              <button type="button" data-theme="high-contrast" aria-pressed="false">High Contrast</button>
            </div>
          </div>
        </div>
        <p class="doc-footer-copyright">&copy; 2026 Pagesmith &middot; Made with <a href="https://github.com/sujeet-pro/pagesmith">Pagesmith</a></p>
      </footer>
    </main>

    <aside class="doc-aside">
      <%- typeof aside !== 'undefined' && aside ? aside : '' %>
    </aside>
  </div>
  <% } %>

  <pagefind-modal reset-on-close>
    <pagefind-modal-header><pagefind-input></pagefind-input></pagefind-modal-header>
    <pagefind-modal-body>
      <pagefind-summary></pagefind-summary>
      <pagefind-results></pagefind-results>
    </pagefind-modal-body>
    <pagefind-modal-footer><pagefind-keyboard-hints></pagefind-keyboard-hints></pagefind-modal-footer>
  </pagefind-modal>

  <dialog class="doc-sidebar-modal" id="sidebar-modal">
    <div class="doc-sidebar-modal-backdrop" data-sidebar-close></div>
    <div class="doc-sidebar-modal-panel">
      <button type="button" class="doc-sidebar-modal-close" data-sidebar-close aria-label="Close navigation">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="m5 5 10 10M15 5 5 15" /></svg>
      </button>
      <nav class="doc-sidebar-nav">
        <% renderSidebarContent() %>
      </nav>
    </div>
  </dialog>

  <% if (typeof js !== 'undefined' && js) { %>
  <script><%- js %></script>
  <% } %>
  <script src="<%= basePath %>pagefind/pagefind-component-ui.js" type="module"></script>
  <script>
    (function() {
      // Sidebar modal
      var sidebarModal = document.getElementById('sidebar-modal');
      var sidebarToggle = document.querySelector('.doc-sidebar-toggle');
      if (sidebarToggle && sidebarModal) {
        function openSidebar() {
          sidebarModal.showModal();
          document.body.style.overflow = 'hidden';
        }
        function closeSidebar() {
          sidebarModal.close();
          document.body.style.overflow = '';
        }
        sidebarToggle.addEventListener('click', openSidebar);
        sidebarModal.querySelectorAll('[data-sidebar-close]').forEach(function(el) {
          el.addEventListener('click', closeSidebar);
        });
        sidebarModal.addEventListener('click', function(e) {
          if (e.target.closest('a')) closeSidebar();
        });
        sidebarModal.addEventListener('cancel', function() {
          document.body.style.overflow = '';
        });
      }

      // TOC highlight on scroll
      var tocLinks = document.querySelectorAll('.doc-toc a[href^="#"]');
      if (tocLinks.length > 0) {
        var headingIds = Array.from(tocLinks).map(function(a) { return a.getAttribute('href').slice(1); });
        var visibleIds = new Set();

        function updateActiveToc() {
          var activeId = null;
          for (var i = 0; i < headingIds.length; i++) {
            if (visibleIds.has(headingIds[i])) { activeId = headingIds[i]; break; }
          }
          tocLinks.forEach(function(link) {
            var li = link.closest('.doc-toc-item');
            if (li) li.classList.toggle('active', link.getAttribute('href') === '#' + activeId);
          });
          var activeItem = document.querySelector('.doc-aside .doc-toc-item.active a');
          if (activeItem) activeItem.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) visibleIds.add(entry.target.id);
            else visibleIds.delete(entry.target.id);
          });
          updateActiveToc();
        }, { rootMargin: '-80px 0px -40% 0px', threshold: 0 });
        headingIds.forEach(function(id) {
          var el = document.getElementById(id);
          if (el) observer.observe(el);
        });
      }

      // Footer theme selector
      var STORAGE_KEY = 'pagesmith-theme';
      function getPrefs() {
        var classes = document.documentElement.className;
        var schemeMatch = classes.match(/color-scheme-(\w+)/);
        var themeMatch = classes.match(/theme-([\w-]+)/);
        return { colorScheme: schemeMatch ? schemeMatch[1] : 'auto', theme: themeMatch ? themeMatch[1] : 'paper' };
      }
      function persistTheme() {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(getPrefs())); } catch(e) {}
      }
      function syncThemeUI() {
        var prefs = getPrefs();
        document.querySelectorAll('[data-footer-scheme] button').forEach(function(btn) {
          var active = btn.dataset.scheme === prefs.colorScheme;
          btn.classList.toggle('active', active);
          btn.setAttribute('aria-pressed', String(active));
        });
        document.querySelectorAll('[data-footer-theme-type] button').forEach(function(btn) {
          var active = btn.dataset.theme === prefs.theme;
          btn.classList.toggle('active', active);
          btn.setAttribute('aria-pressed', String(active));
        });
      }
      document.querySelectorAll('[data-footer-scheme] button').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.dataset.scheme) {
            document.documentElement.className = document.documentElement.className.replace(/color-scheme-\w+/, 'color-scheme-' + btn.dataset.scheme);
            persistTheme(); syncThemeUI();
          }
        });
      });
      document.querySelectorAll('[data-footer-theme-type] button').forEach(function(btn) {
        btn.addEventListener('click', function() {
          if (btn.dataset.theme) {
            document.documentElement.className = document.documentElement.className.replace(/theme-[\w-]+/, 'theme-' + btn.dataset.theme);
            persistTheme(); syncThemeUI();
          }
        });
      });
      syncThemeUI();

    })();
  </script>
</body>
</html>
