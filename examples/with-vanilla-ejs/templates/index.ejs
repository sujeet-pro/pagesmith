<section class="doc-home-section doc-hero">
  <h1 class="doc-hero-text">Pagesmith + EJS</h1>
  <p class="doc-hero-tagline">
    A content-driven site powered by Pagesmith's content layer and EJS templates.
    Browse the guide to learn the fundamentals, or check out the blog for practical insights.
  </p>
  <div class="doc-hero-actions">
    <a href="<%= basePath %>guide/<%= firstGuideSlug %>/" class="doc-hero-action doc-hero-action-brand">
      Read the Guide
    </a>
    <a href="<%= basePath %>blog/<%= firstBlogSlug %>/" class="doc-hero-action doc-hero-action-alt">
      Browse the Blog
    </a>
  </div>
</section>

<section class="doc-home-section">
  <h2>Recent Blog Posts</h2>
  <ul style="display: flex; flex-direction: column; gap: 1rem;">
    <% for (const post of sortedBlog) { %>
      <li style="padding: 1rem 1.25rem; border: 1px solid var(--color-border-subtle); border-radius: var(--radius-lg);">
        <a href="<%= basePath %>blog/<%= post.slug %>/">
          <h3 style="margin: 0; font-size: var(--font-size-lg);"><%= post.title %></h3>
        </a>
        <% if (post.description) { %>
          <p style="margin: 0.5rem 0 0; color: var(--color-text-muted); font-size: var(--font-size-sm);"><%= post.description %></p>
        <% } %>
        <p style="margin: 0.375rem 0 0; font-size: var(--font-size-xs); color: var(--color-text-muted);">
          <time><%= formatDate(post.date) %></time>
          <% if (post.tags && post.tags.length > 0) { %>
            &middot; <%= post.tags.join(', ') %>
          <% } %>
        </p>
      </li>
    <% } %>
  </ul>
</section>

<section class="doc-home-section">
  <h2>Guide</h2>
  <ul style="display: flex; flex-direction: column; gap: 0.75rem;">
    <% for (const entry of sortedGuide) { %>
      <li>
        <a href="<%= basePath %>guide/<%= entry.slug %>/" style="font-weight: 500;"><%= entry.title %></a>
        <% if (entry.description) { %>
          <span style="color: var(--color-text-muted); font-size: var(--font-size-sm);"> &mdash; <%= entry.description %></span>
        <% } %>
      </li>
    <% } %>
  </ul>
</section>
