{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@pagesmith/core": ["../../packages/core/src/index.ts"],
      "@pagesmith/core/*": ["../../packages/core/src/*/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "templates/**/*.ejs",
    "content-config.d.ts",
    "ejs.d.ts",
    "vite.config.ts"
  ]
}
