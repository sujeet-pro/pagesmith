{{#> layout}}
  {{#*inline "body"}}
    <h1>Blog</h1>
    <ul style="list-style: none; padding: 0;">
      {{#each posts}}
        <li style="margin-bottom: 2rem;">
          <h2 style="margin-bottom: 0.25rem;">
            <a href="{{../basePath}}posts/{{this.slug}}/">{{this.title}}</a>
          </h2>
          <time style="color: #666; font-size: 0.875rem;">
            {{formatDate this.date}}
          </time>
          <p style="margin-top: 0.5rem; color: #444;">{{this.description}}</p>
        </li>
      {{/each}}
    </ul>
  {{/inline}}
{{/layout}}
