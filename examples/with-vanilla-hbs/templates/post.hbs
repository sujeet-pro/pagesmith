{{#> layout}}
  {{#*inline "body"}}
    <article style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
      <div>
        <h1 style="margin-bottom: 0.25rem;">{{title}}</h1>
        <div style="color: #666; font-size: 0.875rem; margin-bottom: 1rem;">
          <time>{{formatDate date}}</time>
          {{#if tags.length}}
            &middot;
            {{#each tags}}
              <span style="background: #f0f0f0; padding: 0.125rem 0.5rem; border-radius: 0.25rem; margin-left: 0.25rem;">{{this}}</span>
            {{/each}}
          {{/if}}
        </div>

        {{#if headings.length}}
          <aside style="background: #fafafa; border: 1px solid #e5e5e5; border-radius: 0.5rem; padding: 1rem 1.5rem; margin-bottom: 2rem;">
            <strong style="display: block; margin-bottom: 0.5rem;">Table of Contents</strong>
            <ul style="list-style: none; padding: 0; margin: 0;">
              {{#each headings}}
                <li style="padding-left: {{this.depth}}rem;">
                  <a href="#{{this.slug}}" style="color: #444; text-decoration: none; font-size: 0.875rem;">
                    {{this.text}}
                  </a>
                </li>
              {{/each}}
            </ul>
          </aside>
        {{/if}}

        <div class="prose">
          {{{content}}}
        </div>
      </div>
    </article>
  {{/inline}}
{{/layout}}
