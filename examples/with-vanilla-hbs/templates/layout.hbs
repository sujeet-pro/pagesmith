<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    {{{css}}}
  </style>
  <style>
    /* Layout chrome */
    body {
      margin: 0;
      font-family: system-ui, -apple-system, sans-serif;
      line-height: 1.6;
      color: #1a1a1a;
      background: #fff;
    }
    nav {
      display: flex;
      gap: 1.5rem;
      padding: 1rem 2rem;
      border-bottom: 1px solid #e5e5e5;
      background: #fafafa;
    }
    nav a {
      color: #1a1a1a;
      text-decoration: none;
      font-weight: 500;
    }
    nav a:hover {
      color: #0066cc;
    }
    main {
      max-width: 48rem;
      margin: 2rem auto;
      padding: 0 1.5rem;
    }
  </style>
</head>
<body>
  <nav>
    <a href="{{basePath}}">Home</a>
    <a href="{{basePath}}about/">About</a>
  </nav>
  <main>
    {{{body}}}
  </main>
  <footer style="text-align: center; padding: 2rem 1rem; color: #888; font-size: 0.875rem; border-top: 1px solid #e5e5e5;">
    Built with <a href="https://github.com/sujeet-pro/pagesmith" style="color: #0066cc;">Pagesmith</a>
  </footer>
  {{#if js}}
  <script>{{{js}}}</script>
  {{/if}}
</body>
</html>
