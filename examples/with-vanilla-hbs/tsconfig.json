{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@pagesmith/site": ["../../packages/site/src/index.ts"],
      "@pagesmith/site/*": ["../../packages/site/src/*.ts", "../../packages/site/src/*/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "templates/**/*.hbs",
    "content-config.d.ts",
    "vite.config.ts"
  ]
}
