{{!-- Home route only: lists guide + feature entries; all links come from SSR data, not client fetches. --}}
{{#> layout}}
  {{#*inline "body"}}
    <section class="doc-home-section doc-hero">
      <h1 class="doc-hero-text">Pagesmith + Handlebars</h1>
      <p class="doc-hero-tagline">
        A content-driven site powered by Pagesmith's content layer and Handlebars templates.
        Browse the guide to learn the fundamentals, or open the single markdown kitchen sink.
      </p>
      <div class="doc-hero-actions">
        <a href="{{basePath}}guide/{{firstGuideSlug}}" class="doc-hero-action doc-hero-action-brand">
          Read the Guide
        </a>
        <a href="{{basePath}}guide/{{kitchenSinkSlug}}" class="doc-hero-action doc-hero-action-alt">
          Open Kitchen Sink
        </a>
      </div>
    </section>

    <section class="doc-home-section">
      <h2>Markdown Kitchen Sink</h2>
      <p>
        This example keeps one dedicated regression page for markdown rendering instead of separate
        markdown smoke-test pages.
      </p>
      <p>
        <a href="{{basePath}}guide/{{kitchenSinkSlug}}">Open the kitchen sink page</a>
      </p>
    </section>

    <section class="doc-home-section">
      <h2>Guide</h2>
      <ul style="display: flex; flex-direction: column; gap: 0.75rem;">
        {{#each sortedGuide}}
          <li>
            <a href="{{../basePath}}guide/{{this.slug}}" style="font-weight: 500;">{{this.title}}</a>
            {{#if this.description}}
              <span style="color: var(--color-text-muted); font-size: var(--font-size-sm);"> &mdash; {{this.description}}</span>
            {{/if}}
          </li>
        {{/each}}
      </ul>
    </section>
  {{/inline}}
{{/layout}}
