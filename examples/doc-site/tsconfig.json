{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@pagesmith/site",
    "paths": {
      "@pagesmith/core": ["../../packages/core/src/index.ts"],
      "@pagesmith/core/*": ["../../packages/core/src/*/index.ts"],
      "@pagesmith/docs": ["../../packages/docs/src/index.ts"],
      "@pagesmith/docs/*": ["../../packages/docs/src/*.ts", "../../packages/docs/src/*/index.ts"],
      "@pagesmith/site": ["../../packages/site/src/index.ts"],
      "@pagesmith/site/*": ["../../packages/site/src/*.ts", "../../packages/site/src/*/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
