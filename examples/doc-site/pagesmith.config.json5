        { label: "Hosted Docs", path: "https://projects.sujeet.pro/pagesmith/" },
      ],
    },
  ],
  editLink: {
    repo: "https://github.com/sujeet-pro/pagesmith",
    branch: "main",
    label: "Edit this page",
  },
  lastUpdated: true,
  search: {
    enabled: true,
    showImages: false,
    showSubResults: true,
  },
}
