{
  // Theme configuration for the documentation site.
  // JSON5 supports comments and trailing commas.

  colors: {
    primary: '#3b82f6',
    primaryDark: '#60a5fa',
    accent: '#8b5cf6',
    accentDark: '#a78bfa',
    success: '#22c55e',
    warning: '#eab308',
    error: '#ef4444',
  },

  fonts: {
    sans: 'Inter, system-ui, -apple-system, sans-serif',
    mono: 'JetBrains Mono, Fira Code, monospace',
    heading: 'Inter, system-ui, sans-serif',
  },

  layout: {
    maxContentWidth: '72ch',
    sidebarWidth: '280px',
    headerHeight: '64px',
    footerHeight: '120px',
  },

  code: {
    themes: {
      light: 'github-light',
      dark: 'github-dark',
    },
    showLineNumbers: true,
    copyButton: true,
    wrapLongLines: false,
  },

  components: {
    toc: {
      enabled: true,
      maxDepth: 3,
      sticky: true,
    },
    breadcrumbs: {
      enabled: true,
      separator: '/',
    },
    backToTop: {
      enabled: true,
      threshold: 300,
    },
  },
}
