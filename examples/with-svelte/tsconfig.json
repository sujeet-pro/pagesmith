{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "types": ["vite/client"],
    "paths": {
      "@pagesmith/core/css/content": ["../../packages/core/src/styles/content.css"],
      "@pagesmith/core": ["../../packages/core/src/index.ts"],
      "@pagesmith/core/*": ["../../packages/core/src/*/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "vite.config.ts"]
}
