{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@pagesmith/core/css/content": ["../../packages/core/src/styles/content.css"],
      "@pagesmith/core": ["../../packages/core/src/index.ts"],
      "@pagesmith/core/*": ["../../packages/core/src/*/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
