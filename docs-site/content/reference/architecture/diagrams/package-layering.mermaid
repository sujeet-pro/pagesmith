%% Diagram: Package layering
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
  classDef package fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333333
  classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333333
  classDef optional stroke-dasharray: 6 4

  Docs["@pagesmith/docs\nDocs preset, theme, search,\nbuild/dev/preview pipeline"]
  Site["@pagesmith/site\nCLI, JSX runtime,\nCSS/runtime bundles, SSG helpers"]
  Core["@pagesmith/core\nContent layer, markdown pipeline,\nvalidation, Vite content plugin"]

  DocsSite["Docs sites"]
  CustomSites["Custom sites and examples"]
  FrameworkApps["Framework-hosted apps"]

  Docs --> Site
  Docs --> Core
  Site --> Core

  DocsSite --> Docs
  CustomSites --> Site
  CustomSites --> Core
  FrameworkApps --> Core
  FrameworkApps -. Optional shared content styling/runtime .-> Site

  class Docs,Site,Core package
  class DocsSite,CustomSites,FrameworkApps consumer
  class FrameworkApps optional
