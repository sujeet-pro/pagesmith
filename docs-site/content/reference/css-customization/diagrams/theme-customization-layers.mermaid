%% Diagram: Theme customization layers
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart LR
  subgraph Inputs["Customization inputs"]
    Root[":root base tokens\nplus your global token overrides"]
    Scheme["color-scheme-* on <html>\npicks the light or dark branch"]
    Variant["theme-* on <html>\napplies theme-variant token overrides"]
    Scoped["Scoped selector overrides\ntarget one component or region"]
    Meta["theme.lightColor / theme.darkColor\nconfig values"]
  end

  Tokens["Resolved custom properties\nincluding light-dark() values"]
  Css["Pagesmith CSS bundles\ncontent, layout, code, and components"]
  Ui["Rendered site UI"]
  Chrome["Browser chrome color only"]

  Root --> Tokens
  Scheme --> Tokens
  Variant --> Tokens
  Tokens --> Css
  Css --> Ui
  Scoped --> Ui
  Meta --> Chrome

  style Inputs fill:none,stroke:#5A5A5A,stroke-dasharray:3 3
