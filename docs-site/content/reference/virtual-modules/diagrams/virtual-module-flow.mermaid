%% Diagram: Virtual module flow
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart LR
  classDef source fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333333
  classDef plugin fill:#ffe6cc,stroke:#d6b656,stroke-width:2px,color:#333333
  classDef output fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333333
  classDef consumer fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333333

  Config["content.config.ts<br/>Collections + Zod schemas"]
  Files["content/**<br/>Markdown and data files"]
  Plugin["pagesmithContent()<br/>Vite plugin"]
  RootModule["virtual:content<br/>All collections"]
  CollectionModule["virtual:content/posts<br/>Single collection"]
  Dts["pagesmith-content.d.ts<br/>Generated module types"]
  App["App or SSG entry<br/>Imports virtual modules"]
  IDE["TypeScript + editor<br/>Autocomplete and type checking"]

  Config --> Plugin
  Files --> Plugin
  Plugin --> RootModule
  Plugin --> CollectionModule
  Plugin --> Dts
  RootModule --> App
  CollectionModule --> App
  Dts -. Keeps imports schema-aware .-> App
  Dts --> IDE

  class Config,Files source
  class Plugin plugin
  class RootModule,CollectionModule,Dts output
  class App,IDE consumer
