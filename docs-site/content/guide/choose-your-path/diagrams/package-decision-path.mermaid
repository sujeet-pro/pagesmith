%% Diagram: Package decision path
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TD
    start([Start here]) --> docsQ{"Need built-in docs navigation,\nsearch, and the default theme?"}
    docsQ -- Yes --> docs["@pagesmith/docs\nDocs preset with config,\nnavigation, search, and theme"]
    docsQ -- No --> hostQ{"Does the host app already own\nrouting, layout, and build tooling?"}
    hostQ -- Yes --> core["@pagesmith/core\nHeadless content layer with\nschemas, loaders, and markdown"]
    hostQ -- No --> site["@pagesmith/site + @pagesmith/core\nCustom site shell with shared\nJSX, CSS/runtime, and Vite SSG"]
    core --> siteQ{"Need the shared Pagesmith\nsite layer too?"}
    siteQ -- Yes --> site
    siteQ -- No --> coreOnly["Stay on @pagesmith/core"]
