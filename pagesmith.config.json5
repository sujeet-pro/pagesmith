{
  $schema: './node_modules/@pagesmith/docs/schemas/pagesmith-config.schema.json',
  preset: '@pagesmith/docs',
  name: 'Pagesmith',
  title: 'Pagesmith',
  description: 'File-based CMS and static site generator',
  origin: 'https://projects.sujeet.pro',
  contentDir: './docs/content',
  outDir: './gh-pages',
  basePath: '/pagesmith',
  maintainer: {
    name: 'Sujeet Jaiswal',
    link: 'https://sujeet.pro',
  },
  copyright: {
    projectName: 'Pagesmith',
    startYear: 2026,
    endYear: null,
  },
  footerLinks: [
    {
      header: 'Pagesmith',
      links: [
        { label: 'Overview', path: '/' },
        { label: 'Philosophy', path: '/#philosophy' },
        { label: 'Architecture', path: '/reference/architecture' },
        { label: 'Choose Your Path', path: '/guide/choose-your-path' },
      ],
    },
    {
      header: 'Core',
      links: [
        { label: 'Getting Started', path: '/guide/getting-started' },
        { label: 'Collections & Loaders', path: '/guide/collections-and-loaders' },
        { label: 'Validation & Rendering', path: '/guide/validation-and-rendering' },
        { label: 'API Reference', path: '/reference/api' },
      ],
    },
    {
      header: 'Docs',
      links: [
        { label: 'Docs Getting Started', path: '/guide/docs-getting-started' },
        { label: 'Docs Config', path: '/reference/docs-config' },
        { label: 'Docs Theme', path: '/reference/docs-theme' },
        { label: 'Docs CLI', path: '/reference/docs-cli' },
      ],
    },
    {
      header: 'Author',
      links: [
        { label: 'Profile', path: 'https://sujeet.pro' },
        { label: 'Articles', path: 'https://sujeet.pro/articles.html' },
        { label: 'GitHub', path: 'https://github.com/sujeet-pro' },
        { label: 'Repository', path: 'https://github.com/sujeet-pro/pagesmith' },
      ],
    },
  ],
  editLink: {
    repo: 'https://github.com/sujeet-pro/pagesmith',
    branch: 'main',
  },
  lastUpdated: true,
  search: {
    enabled: true,
  },
  assets: {
    '/': ['./llms.txt', './llms-full.txt', './packages/docs/schemas'],
    '/prompts': ['./packages/docs/ai-guidelines/setup-docs.md'],
  },
}
