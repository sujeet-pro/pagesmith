%% Diagram: Base path resolution priority
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TD
  cliFlag["CLI --base-path"]
  envVar["BASE_URL"]
  configFile["pagesmith.config.json5 basePath"]
  gitRemote["Git remote repo name"]
  defaultRoot["Default /"]
  cliFlag -->|"if unset"| envVar
  envVar -->|"if unset"| configFile
  configFile -->|"if unset"| gitRemote
  gitRemote -->|"if unset"| defaultRoot
