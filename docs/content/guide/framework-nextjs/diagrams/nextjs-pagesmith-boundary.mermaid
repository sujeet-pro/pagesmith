%% Diagram: Next.js Pagesmith boundary
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
  routes["Next.js App Router\nroutes / layouts /\nstatic export shell"]

  layer["createContentLayer()\ndefineCollection() +\ndefineConfig()"]
  render["entry.render()\nHTML / headings /\nreadTime"]
  assets["@pagesmith/site\ncss/content +\nruntime/content"]

  engine["@pagesmith/core\nCollections, markdown,\nvalidation"]

  routes --> layer --> render --> routes
  assets --> routes
  engine -. powers .-> layer
  engine -. powers .-> render
