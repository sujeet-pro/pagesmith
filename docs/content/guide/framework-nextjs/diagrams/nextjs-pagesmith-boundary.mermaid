flowchart TB
    subgraph next["Next.js App Router"]
        routes["Routes layouts metadata<br/>static export shell"]
    end

    subgraph site["@pagesmith/site app-facing package"]
        layer["createContentLayer()<br/>defineCollection() + defineConfig()"]
