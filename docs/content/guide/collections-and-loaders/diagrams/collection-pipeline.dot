// Diagram: Collection pipeline
// Type: graphviz
digraph CollectionPipeline {
  bgcolor="transparent"
  graph [rankdir=TB, nodesep=0.25, ranksep=0.4, pad=0.1, fontsize=10]
  node [shape=box, style="rounded,filled", fillcolor="#dae8fc", color="#6c8ebf", fontcolor="#333333", fontsize=10, margin="0.12,0.07"]
  edge [fontsize=9, color="#AAAAAA", fontcolor="#333333"]

  files [label="Files\ncontent/posts/*.md\ncontent/authors/*.yaml"]
  loader [label="Loader\nmd / json / yaml /\ncustom"]

  raw [label="RawEntry\ndata + content + slug"]
  slugify [label="slugify()\noptional URL rule"]

  transform [label="transform()\noptional pre-validation"]
  schema [label="schema\nZod validate + coerce"]

  derived [label="computed /\nvalidate / validators"]
  filter [label="filter()\nexclude entries"]

  entries [label="Collection entries\ntyped data + slug"]
  consume [label="Consume via\ncreateContentLayer() /\npagesmithContent()"]

  { rank=same; files; loader }
  { rank=same; raw; slugify }
  { rank=same; transform; schema }
  { rank=same; derived; filter }
  { rank=same; entries; consume }

  files -> loader -> raw
  raw -> transform -> schema -> derived
  derived -> filter -> entries -> consume

  files -> slugify [style=dashed]
  slugify -> raw [style=dashed]
}
