%% Diagram: Seven Pagesmith principles
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
  hub(["Pagesmith\nseven locked principles"]):::hub

  hub --- filesystem["1. Filesystem-first\nsource of truth\ncollections, assets, nav on disk"]:::tenet
  hub --- boundaries["2. Strict package\nboundaries\ncore / site / docs"]:::tenet
  hub --- validation["3. Validation before\nrender or runtime\nZod + content validators"]:::tenet
  hub --- vite["4. Vite-native\nexecution\nno custom toolchain"]:::tenet
  hub --- progressive["5. Progressive\nenhancement\nHTML first, JS optional"]:::tenet
  hub --- config["6. Configuration\nbefore customization\nJSON5 over TypeScript"]:::tenet
  hub --- parity["7. Docs, examples,\nAI guidance move together\nsame branch, same PR"]:::tenet

  classDef hub fill:#2E5A88,stroke:#1F4870,color:#ffffff
  classDef tenet fill:#1F6E68,stroke:#155752,color:#ffffff
