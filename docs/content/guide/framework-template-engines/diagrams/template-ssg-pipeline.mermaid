%% Diagram: Template SSG pipeline
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TD
    cfg["content.config.mjs\ndefineCollection + schemas"]
    vite["Vite config\npagesmithSsg + sharedAssetsPlugin"]
    entry["SSR entry server\ngetLayer per root"]
    layer["createContentLayer()"]
    md["entry.render()\nmarkdown to HTML"]
    tpl["EJS or Handlebars\nlayout + page bodies"]
    out["Static HTML + assets\nPagefind optional"]

    cfg --> layer
    vite --> entry
    entry --> layer
    layer --> md
    md --> tpl
    tpl --> out
