%% Diagram: Core integration paths
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TD
    files["Content files\nmarkdown, JSON, assets"]
    config["content.config.ts\ndefineCollection() +\ndefineConfig()"]

    files --> config

    config --> layer["createContentLayer()\nshared typed layer"]
    layer --> direct["getCollection() +\nentry.render()"]
    direct --> framework["Framework host\nor custom SSR app"]

    config --> contentPlugin["pagesmithContent()\nfrom @pagesmith/core/vite"]
    contentPlugin --> virtual["virtual:content/*\nmodules"]
    virtual --> viteApp["Vite application code"]

    config --> sitePlugin["Optional pagesmithSsg()\nfrom @pagesmith/site/vite"]
    sitePlugin --> viteApp
    viteApp --> staticOutput["Dev SSR or\nstatic route output"]
