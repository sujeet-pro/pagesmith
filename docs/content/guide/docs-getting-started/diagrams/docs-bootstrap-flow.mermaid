%% Diagram: Docs bootstrap flow
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
    install["npm add @pagesmith/docs\npulls @pagesmith/core"]
    init["pagesmith-docs init\n--yes --ai"]
    cfg["pagesmith.config.json5\n+ schema pointer"]
    tree["Markdown content tree\n+ meta.json5"]
    scripts["package.json scripts\ndev build preview"]
    ship["Static outDir\n+ Pagefind index"]

    install --> init
    init --> cfg
    init --> tree
    init --> scripts
    scripts --> ship
