%% Diagram: Package decision path
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
    start([Start here]) --> docsQ{"Need built-in docs nav,\nsearch, theme?"}
    docsQ -- Yes --> docs["@pagesmith/docs"]
    docsQ -- No --> hostQ{"Host owns routing,\nlayout, build?"}
    hostQ -- Yes --> core["@pagesmith/core"] --> siteQ{"Need site layer too?"}
    hostQ -- No --> site["@pagesmith/site\n+ @pagesmith/core"]
    siteQ -- Yes --> site
    siteQ -- No --> coreOnly["Stay on @pagesmith/core"]
