%% Diagram: AI artifact install flow
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TD
    pick{"Project shape?"}
    docs["npx pagesmith-docs init --ai\nscaffold + AI artifacts"]
    coreai["npx pagesmith-core ai --profile default\nAI artifacts only"]
    shared["Installed AI artifacts\nmemory files skills commands\nmarkdown rules llms.txt"]

    pick -->|"docs site"| docs
    pick -->|"core or site app"| coreai
    docs --> shared
    coreai --> shared
