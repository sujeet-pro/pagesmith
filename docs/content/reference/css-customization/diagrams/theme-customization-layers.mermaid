%% Diagram: Theme customization layers
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart LR
  subgraph Inputs["Customization inputs"]
    Root[":root base tokens<br/>plus your global token overrides"]
    Scheme["color-scheme-* on <html><br/>picks the light or dark branch"]
    Variant["theme-* on <html><br/>applies theme-variant token overrides"]
    Scoped["Scoped selector overrides<br/>target one component or region"]
    Meta["theme.lightColor / theme.darkColor<br/>config values"]
  end

  Tokens["Resolved custom properties<br/>including light-dark() values"]
  Css["Pagesmith CSS bundles<br/>content, layout, code, and components"]
  Ui["Rendered site UI"]
  Chrome["Browser chrome color only"]

  Root --> Tokens
  Scheme --> Tokens
  Variant --> Tokens
  Tokens --> Css
  Css --> Ui
  Scoped --> Ui
  Meta --> Chrome
