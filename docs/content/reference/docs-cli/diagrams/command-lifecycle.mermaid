%% Diagram: Command lifecycle
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TD
  start([Project or existing repo])
  init["pagesmith-docs init\nScaffold or backfill config and starter docs"]
  dev["pagesmith-docs dev\nLive-reload editing loop"]
  build["pagesmith-docs build\nStatic output + assets + Pagefind"]
  preview["pagesmith-docs preview\nServe built output from disk"]
  mcp["pagesmith-docs mcp --stdio\nExpose docs-aware MCP tools"]

  start --> init
  start --> dev
  init --> dev
  dev --> build
  build --> preview
  start -. "assistant or tooling access" .-> mcp
  init -. "project metadata + content" .-> mcp
