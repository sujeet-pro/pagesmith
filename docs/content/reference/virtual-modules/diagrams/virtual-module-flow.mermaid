%% Diagram: Virtual module flow
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
  classDef source fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333333
  classDef plugin fill:#ffe6cc,stroke:#d6b656,stroke-width:2px,color:#333333
  classDef output fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333333
  classDef consumer fill:#e1d5e7,stroke:#9673a6,stroke-width:2px,color:#333333

  Config["content.config.ts\nCollections + Zod schemas"]
  Files["content/**\nMarkdown and data files"]
  Plugin["pagesmithContent()\nVite plugin"]
  RootModule["virtual:content\nAll collections"]
  CollectionModule["virtual:content/posts\nSingle collection"]
  Dts["pagesmith-content.d.ts\nGenerated module types"]
  App["App or SSG entry\nImports virtual modules"]
  IDE["TypeScript + editor\nAutocomplete and type checking"]

  Config --> Plugin
  Files --> Plugin
  Plugin --> RootModule
  Plugin --> CollectionModule
  Plugin --> Dts
  RootModule --> App
  CollectionModule --> App
  Dts -. Keeps imports schema-aware .-> App
  Dts --> IDE

  class Config,Files source
  class Plugin plugin
  class RootModule,CollectionModule,Dts output
  class App,IDE consumer
