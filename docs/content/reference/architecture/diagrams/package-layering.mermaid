%% Diagram: Package layering
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
  classDef package fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px,color:#333333
  classDef consumer fill:#d5e8d4,stroke:#82b366,stroke-width:2px,color:#333333
  classDef optional stroke-dasharray: 6 4

  Docs["@pagesmith/docs\nDocs preset, theme, search,\nbuild pipeline"]
  Site["@pagesmith/site\nCLI, JSX runtime,\nCSS/runtime, SSG"]
  Core["@pagesmith/core\nContent layer, markdown,\nvalidation, Vite plugin"]

  DocsSite["Docs sites"]
  CustomSites["Custom sites\nand examples"]
  FrameworkApps["Framework-hosted\napps"]

  Docs --> Site
  Docs --> Core
  Site --> Core

  DocsSite --> Docs
  CustomSites --> Site
  CustomSites --> Core
  FrameworkApps --> Core
  FrameworkApps -. optional .-> Site

  class Docs,Site,Core package
  class DocsSite,CustomSites,FrameworkApps consumer
  class FrameworkApps optional
