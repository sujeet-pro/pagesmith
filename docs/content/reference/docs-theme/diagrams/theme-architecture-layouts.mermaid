%% Diagram: Docs theme - layouts and document
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
  Inputs["Resolved docs config\n+ docs page data\n(theme, search, links,\nbreadcrumbs, sidebarSections,\nheadings, prev/next, listings)"]

  Layouts["Docs-owned layouts\nDocHome / DocPage /\nDocListing / DocNotFound"]

  Html["theme/components/Html.tsx\nre-exports SiteDocument"]
  Markdown["Rendered markdown\nhtml body"]

  Runtime["theme/runtime/main.ts\nstandalone runtime"]
  Styles["theme/styles/main.css\nsite + docs overrides"]

  Inputs --> Layouts
  Layouts --> Html
  Layouts --> Markdown

  Html -. loads .-> Runtime
  Html -. loads .-> Styles
  Styles -. styles .-> Markdown
