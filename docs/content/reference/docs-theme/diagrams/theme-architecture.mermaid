---
title: Docs theme architecture overview
---
%% Diagram: Docs theme architecture overview
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
  Config["Resolved docs config<br/>theme, search, links, metadata"]
  PageData["Resolved docs page data<br/>breadcrumbs, sidebarSections,<br/>headings, prev/next, listings"]
  Html["theme/components/Html.tsx<br/>re-export -> SiteDocument"]
  Shell["PageShell<br/>shared site shell"]
  Runtime["theme/runtime/main.ts<br/>imports @pagesmith/site/runtime/standalone"]
  Styles["theme/styles/main.css<br/>site fonts + standalone CSS<br/>plus docs home / 404 overrides"]
  Markdown["Rendered markdown<br/>html body"]

  subgraph Layouts["Docs-owned layouts"]
    Home["DocHome"]
    Page["DocPage"]
    Listing["DocListing"]
    NotFound["DocNotFound"]
  end

  subgraph Shared["Shared site surface"]
    Header["SiteHeader"]
    Sidebar["SiteSidebar"]
    SidebarModal["SiteSidebarModal"]
    TOC["TableOfContents"]
    Footer["SiteFooter"]
  end

  Config --> Layouts
  PageData --> Layouts
  Layouts --> Html
  Page --> Shell
  Listing --> Shell
  Shell --> Header
  Shell --> Sidebar
  Shell --> SidebarModal
  Shell --> TOC
  Shell --> Footer
  Page --> Markdown
  Listing --> Markdown
  Home --> Header
  Home --> SidebarModal
  Home --> Footer
  Home --> Markdown
  NotFound --> Header

  Html -. loads .-> Runtime
  Html -. loads .-> Styles
  Runtime -. enhances .-> Shell
  Styles -. styles .-> Layouts
  Styles -. styles .-> Markdown
