---
title: Docs theme architecture overview
---
%% Diagram: Docs theme architecture overview
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%

flowchart TB
  Config["Resolved docs config\ntheme, search, links, metadata"]
  PageData["Resolved docs page data\nbreadcrumbs, sidebarSections,\nheadings, prev/next, listings"]
  Html["theme/components/Html.tsx\nre-export -> SiteDocument"]
  Shell["PageShell\nshared site shell"]
  Runtime["theme/runtime/main.ts\nimports @pagesmith/site/runtime/standalone"]
  Styles["theme/styles/main.css\nsite fonts + standalone CSS\nplus docs home / 404 overrides"]
  Markdown["Rendered markdown\nhtml body"]

  subgraph Layouts["Docs-owned layouts"]
    Home["DocHome"]
    Page["DocPage"]
    Listing["DocListing"]
    NotFound["DocNotFound"]
  end

  subgraph Shared["Shared site surface"]
    Header["SiteHeader"]
    Sidebar["SiteSidebar"]
    SidebarModal["SiteSidebarModal"]
    TOC["TableOfContents"]
    Footer["SiteFooter"]
  end

  Config --> Layouts
  PageData --> Layouts
  Layouts --> Html
  Page --> Shell
  Listing --> Shell
  Shell --> Header
  Shell --> Sidebar
  Shell --> SidebarModal
  Shell --> TOC
  Shell --> Footer
  Page --> Markdown
  Listing --> Markdown
  Home --> Header
  Home --> SidebarModal
  Home --> Footer
  Home --> Markdown
  NotFound --> Header

  Html -. loads .-> Runtime
  Html -. loads .-> Styles
  Runtime -. enhances .-> Shell
  Styles -. styles .-> Layouts
  Styles -. styles .-> Markdown

  style Layouts fill:none,stroke:#5A5A5A,stroke-dasharray:3 3
  style Shared fill:none,stroke:#5A5A5A,stroke-dasharray:3 3
